<ModOps>

    <!-- Specialist AE-NR-Bath-Red-Soap-E -->
    <Group>
        <ModOp Add="/TextExport/Texts">
        <!-- Title -->
        <Text>
            <Text>Valerius Saponius, Master of the Soap</Text>
            <LineId>1600000044</LineId> <!-- <GUID>1600000044</GUID> -->
        </Text>
        <!-- Description -->
        <Text>
            <Text>By using soap in big pools of water we can clean so many people at once. &#xD;Hint: The Effects are applying to every building in Street Range.</Text>
            <LineId>1600000045</LineId> 
        </Text>
        </ModOp>
    </Group>

